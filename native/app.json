{
  "expo": {
    "name": "吉他学习",
    "slug": "guitar-learner-app",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a2128"
    },
    "orientation": "portrait",
    "scheme": "guitarlearner",
    "userInterfaceStyle": "automatic",
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#0f1419",
      "translucent": false
    },
    "android": {
      "package": "com.you.guitarlearner",
      "backgroundColor": "#0f1419",
      "navigationBar": {
        "backgroundColor": "#0f1419",
        "barStyle": "light-content"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.you.guitarlearner",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "需要使用麦克风进行调音和音高识别"
      }
    },
    "plugins": [
      "expo-router",
      "./plugins/copy-web-assets",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c99e4024-bde3-4455-868d-684d2e91e46c"
      }
    },
    "owner": "jingjingjingjing"
  }
}
