{
  "name": "guitar-learner",
  "private": true,
  "version": "1.0.0",
  "description": "纯本地运行的吉他学习应用：和弦、音阶、指板、乐理与节拍器练习",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/inline-dist.mjs",
    "preview": "vite preview --host",
    "eval": "node scripts/eval-chord-detector.mjs",
    "eval:update": "node scripts/eval-chord-detector.mjs --update-baseline",
    "eval:check": "node scripts/eval-chord-detector.mjs --check-baseline"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.8"
  }
}